VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-public-key

# Worker runtime configuration for the registration lookup proxy.
# For local development, keep these in `.env.local` or `.dev.vars`.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-public-key

# Worker secret for the registration lookup proxy.
# Set in Cloudflare with `wrangler secret put`, never VITE_ prefixed.
# PLATEAPI_API_KEY=your-plateapi-server-only-key
